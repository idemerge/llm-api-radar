# Server port
PORT=3001

# Auth credentials (change these before deploying)
AUTH_USERNAME=admin
AUTH_PASSWORD=changeme

# JWT configuration (leave empty to auto-generate a secure secret)
JWT_SECRET=
JWT_EXPIRES_IN=24h

# Encryption secret for API key storage (leave empty to auto-generate)
ENCRYPTION_SECRET=

# CORS origin (leave empty for same-origin only, or set to e.g. https://your-domain.com)
CORS_ORIGIN=
